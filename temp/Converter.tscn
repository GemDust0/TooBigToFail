[node name="Converter" type="RichTextLabel" unique_id=1678192672]
offset_right = 721.0
offset_bottom = 451.0
text = "static Dictionary<char, int> romanDigits = new(){
	{ 'I', 1 },
	{ 'V', 5 },
	{ 'X', 10 },
	{ 'L', 50 },
	{ 'C', 100 },
	{ 'D', 500 },
	{ 'M', 1000 }
};
    
public int RomanToInt(string s){
	var result = 0;
	for(int i = 0; i < s.Length - 1; i++){
		if(romanDigits[s[\\i]] < romanDigits[s[i + 1]]){
			result -= romanDigits[s[\\i]];
		}
		else{
			result += romanDigits[s[\\i]];
		}
	}
	return result + romanDigits[s[s.Length - 1]];
}"
script = ExtResource("1_javoe")
