codeArray = PackedStringArray("public void DoFizzBuzz(int target){[\\n]    for (int i = 1; i <= target; i++){[\\n]        bool fizz = i % 3 == 0;[\\n]        bool buzz = i % 5 == 0;[\\n]        if (fizz){[\\n]            Console.Write(\"Fizz\");[\\n][\\t][\\t]}[\\n]        if (buzz){[\\n]            Console.Write(\"Buzz\");[\\n][\\t][\\t]}[\\n]        if (!(fizz || buzz)){[\\n]            Console.Write(i);[\\n][\\t][\\t]}[\\n][\\t][\\t]Console.Write(\"\\n\");[\\n]    }[\\n]}", "public void DoFizzBuzz(int target){[\\n]    for (int i=1; i <= target; i++){[\\n]        bool fizz = i % 3 == 0;[\\n]        bool buzz = i % 5 == 0;[\\n]        if (fizz){[\\n]            Console.Write(\"Fizz\");[\\n][\\t][\\t]}[\\n]        if (buzz){[\\n]            Console.Write(\"Buzz\");[\\n][\\t][\\t]}[\\n]        if (!(fizz || buzz)){[\\n]            Console.Write(i);[\\n][\\t][\\t]}[\\n][\\t][\\t]Console.Write(\"\\n\");[\\n]    }[\\n]}")

