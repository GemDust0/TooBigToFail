codeArray = PackedStringArray("using System;[\\n][\\n]class Program{[\\n][\\t]static void Main(string[] args){[\\n]    [\\t]Console.WriteLine(\"Hello World!\");[\\n][\\t]}[\\n]}", "public void FizzBuzz(int target){[\\n]    for (int i=1; i <= target; i++){[\\n]        bool fizz = i%3 == 0;[\\n]        bool buzz = i%5 == 0;[\\n]        if (fizz){[\\n]            Console.Write(\"Fizz\");[\\n][\\t][\\t]}[\\n]        if (buzz){[\\n]            Console.Write(\"Buzz\");[\\n][\\t][\\t]}[\\n]        if (!(fizz || buzz)){[\\n]            Console.Write(i);[\\n][\\t][\\t]}[\\n][\\t][\\t]Console.Write(\"\\n\");[\\n]    }[\\n]}", "public unsafe float InvSqrt(float x){[\\n][\\t]float xhalf = 0.5f*x;[\\n][\\t]int i = *(int*)&x;[\\n][\\t]i = 0x5f3759df - (i>>1);[\\n][\\t]x = *(float*)&i;[\\n][\\t]x = x*(1.5f - xhalf*x*x);[\\n][\\t]return x;[\\n]}", "static Dictionary<char, int> romanDigits = new(){[\\n][\\t]{\'I\', 1},[\\n][\\t]{\'V\', 5},[\\n][\\t]{\'X\', 10},[\\n][\\t]{\'L\', 50},[\\n][\\t]{\'C\', 100},[\\n][\\t]{\'D\', 500},[\\n][\\t]{\'M\', 1000}[\\n]};[\\n][\\n]public int RomanToInt(string s){[\\n][\\t]int result = 0;[\\n][\\t]for (int index = 0; index < s.Length - 1; index++){[\\n][\\t][\\t]if (romanDigits[s[index]] < romanDigits[s[index + 1]]){[\\n][\\t][\\t][\\t]result -= romanDigits[s[index]];[\\n][\\t][\\t]}else{[\\n][\\t][\\t][\\t]result += romanDigits[s[index]];[\\n][\\t][\\t]}[\\n][\\t]}[\\n][\\t]return result + romanDigits[s[s.Length - 1]];[\\n]}")
